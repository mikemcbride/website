---
const currentYear = new Date().getFullYear();
---
<footer class="font-sans mt-16 lg:mt-24 px-4 lg:px-8 py-12 border-t border-zinc-200 dark:border-zinc-700 w-full relative">
    <div class="w-screen absolute left-0 -top-px h-px bg-zinc-200 dark:bg-zinc-700"></div>
    <div class="w-screen absolute right-0 -top-px h-px bg-zinc-200 dark:bg-zinc-700"></div>
    <section class="w-full flex flex-wrap items-center justify-start gap-6">
        <span class="text-sm lg:text-base text-zinc-500 dark:text-zinc-400 w-full md:w-auto md:mr-auto">&copy; <span id="year">{currentYear}</span> Mike McBride</span>
        <a class="text-sm lg:text-base text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white" href="https://github.com/mikemcbride" target="_blank" rel="noreferrer nofollow">GitHub</a>
        <a class="text-sm lg:text-base text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white" href="https://vmst.io/@mcbridem" target="_blank" rel="me">Mastodon</a>
    </section>
</footer>

