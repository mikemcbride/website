---
const isActive = Astro.props.href === '/' ?
    Astro.routePattern === '/' :
    Astro.routePattern.startsWith(Astro.props.href);
---
<li>
    <a class={`font-display uppercase relative block px-3 py-2 transition hover:text-teal-600 dark:hover:text-teal-400 ${isActive ? 'text-teal-600 dark:text-teal-400' : ''}`} href={Astro.props.href}><slot /></a>
</li>
